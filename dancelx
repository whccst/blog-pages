<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>AI显示</title>
</head>
<body>

<div id="box">加载中...</div>

<script>
async function load() {
  const res = await fetch("https://ask.132804.xyz/?trust_key=dancelx&info=%E5%B8%AE%E6%88%91%E5%86%99%E4%B8%80%E4%B8%AA%E6%9C%80%E7%AE%80%E5%8D%95%E7%9A%84html%E7%BD%91%E9%A1%B5%E4%BB%A3%E7%A0%81"); // 你的 Worker 地址
  const data = await res.json();

  const element = document.getElementById("box");

  // 👉 就写在这里
  element.innerText = data.text;
}

load();
</script>

</body>
</html>
